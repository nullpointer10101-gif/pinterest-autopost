# AI provider config (OpenAI or OpenAI-compatible providers like Qwen)
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=

# Legacy OpenAI-only config (still supported)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=
OPENAI_MODEL=

# Optional Qwen/DashScope aliases (also supported)
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus

# Pinterest API Credentials
PINTEREST_APP_ID=your_pinterest_app_id
PINTEREST_APP_SECRET=your_pinterest_app_secret
PINTEREST_ACCESS_TOKEN=your_pinterest_access_token
PINTEREST_POSTING_MODE=auto
# Posting mode:
# - auto: use browser bot locally, API mode on serverless
# - api: always use Pinterest API (recommended for free hosting)
# - bot: force browser bot when available

# RapidAPI Key (for Instagram data extraction)
RAPIDAPI_KEY=your_rapidapi_key_here

# Server Config
PORT=3000
NODE_ENV=development

# Automation (online worker)
AUTOMATION_SECRET=
AUTOMATION_TIMEZONE=Asia/Calcutta
AUTOMATION_MAX_POSTS_PER_DAY=10
AUTOMATION_MAX_POSTS_PER_RUN=2
AUTOMATION_ENGAGEMENTS_PER_HOUR=2
AUTOMATION_ENGAGEMENTS_HARD_CAP=2
AUTOMATION_ENGAGEMENT_START_JITTER_MIN_MS=60000
AUTOMATION_ENGAGEMENT_START_JITTER_MAX_MS=480000
AUTOMATION_ENGAGEMENT_MIN_GAP_MS=480000
AUTOMATION_ENGAGEMENT_MAX_GAP_MS=1320000
AUTOMATION_COMMENT_PROBABILITY=0.85

# Cloud state storage (recommended for Vercel + GitHub Actions)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
APP_STATE_KEY=pinterest_autopost_state_v1

# Direct Reel Studio / Auto Editor
# AUTO_EDITOR_AUDIO_PATH should point to an audio file you own or are licensed to use.
AUTO_EDITOR_WATERMARK=Shop The Look
AUTO_EDITOR_AUDIO_PATH=
AUTO_EDITOR_MAX_SECONDS=28
AUTO_EDITOR_MAX_SOURCE_MB=120
AUTO_EDITOR_RENDER_TIMEOUT_MS=240000

# Product search credit guardrails
# Defaults are intentionally conservative so one post cannot burn many Serper credits.
PRODUCT_SEARCH_CACHE_TTL_MS=21600000
PRODUCT_SEARCH_MAX_INITIAL_QUERIES=2
PRODUCT_SEARCH_MAX_FLIPKART_QUERIES=2
PRODUCT_SEARCH_MAX_QUERIES_PER_ROLE=1
PRODUCT_SEARCH_MAX_MARKETPLACES_PER_ROLE=1
PRODUCT_SEARCH_MAX_VALIDATION_CANDIDATES=2
PRODUCT_HUNTER_ROLES=exact_flipkart,budget_pick
PRODUCT_HUNTER_MAX_ROLES=2
AMAZON_SERPER_QUERY_VARIANTS=1
SERPER_IMAGE_LOOKUP_ENABLED=true
SERPER_MAX_IMAGE_SEARCHES_PER_POST=2
