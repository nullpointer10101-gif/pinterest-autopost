# Dependencies
node_modules/

# Environment variables (NEVER commit these)
.env
.env.local
.env.production
.env.vercel*

# Local database and private user data (never commit)
data/db.json
data/state.json
data/leads.json
data/ig-tracker-state.json

# Pinterest automation state files ARE tracked in git
# (needed for GitHub Actions to persist queue and repost log across runs)
# data/pinterest_queue.json      ← tracked
# data/pinterest_reposted.json   ← tracked
# data/pinterest_accounts.json   ← tracked
# data/pinterest_pins.json       ← tracked

# Logs
*.log
npm-debug.log*
logs/
public/logs/
debug_screenshots/
debug_screenshots.zip
ig-repost-run-*/
ig-repost-run-*.zip
job_log_*.txt
status.txt
temp_out.html
test.html

# Local secrets / scratch
UPSTASH_CREDENTIALS.txt
scratch/

# OS artifacts
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Puppeteer cached browser (too large for deployment)
.local-chromium/
.cache/puppeteer/

# Media & Screenshots
*.png
*.jpg
*.jpeg
*.gif
public/generated/
!public/assets/
!public/assets/creator-opening/
!public/assets/creator-opening/*.jpg


# Build artifacts
dist/
build/
.next/
out/

.vercel
.env*.local
