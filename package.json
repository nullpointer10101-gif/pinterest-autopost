    "@react-three/postprocessing": "2.19.1",
    "@tailwindcss/postcss": "^4.3.0",
    "autoprefixer": "^10.5.0",
    "framer-motion": "^11.18.2",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "lucide-react": "^1.16.0",
    "next": "^14.2.35",
    "nodemon": "^3.0.2",
    "postcss": "^8.5.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.184.0",
    "tailwindcss": "^4.3.0"
