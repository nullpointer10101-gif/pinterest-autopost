    "express": "^4.18.2",
    "form-data": "^4.0.0",
    "instagram-url-direct": "^2.0.7",
    "jsdom": "^29.1.1",
    "lowdb": "^1.0.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0",
    "openai": "^4.20.1",
    "puppeteer": "^24.41.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "uuid": "^9.0.0"
